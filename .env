# ── File Paths ──────────────────────────────────────────
INPUT_FILE=Split_Data_Part_1.csv
OUTPUT_FILE=Enriched_Data_Output_Ultimate.csv

# ── Timing ───────────────────────────────────────────────
DELAY_SECONDS=15
BLOCK_WAIT_MINUTES=30

# ── Behaviour ────────────────────────────────────────────
HEADLESS=true
MIN_CONFIDENCE_SCORE=60

# ── Proxy Configuration ──────────────────────────────────
# Options: "auto", "none", "brightdata", "oxylabs", "smartproxy", "generic", "manual"
PROXY_SERVICE=none

# Auto-switch mode (tries providers in order and falls back to direct)
# PROXY_SERVICE=auto
AUTO_PROVIDER_PRIORITY=smartproxy,oxylabs,brightdata,generic,manual,none
PROXY_AUTO_SWITCH=true

# Bright Data (formerly Luminati) - https://brightdata.com
# PROXY_SERVICE=brightdata
# BRIGHTDATA_USERNAME=your-username
# BRIGHTDATA_PASSWORD=your-password
# BRIGHTDATA_ZONE=residential

# Oxylabs - https://oxylabs.io
# PROXY_SERVICE=oxylabs
# OXYLABS_USERNAME=your-username
# OXYLABS_PASSWORD=your-password

# SmartProxy - https://smartproxy.com
# PROXY_SERVICE=smartproxy
# SMARTPROXY_USERNAME=your-username
# SMARTPROXY_PASSWORD=your-password

# Generic provider (works with any rotating proxy gateway URL)
# PROXY_SERVICE=generic
# GENERIC_PROXY_URL=http://username:password@gateway.provider.com:10000
# GENERIC_PROXY_POOL=http://u:p@ip1:port,http://u:p@ip2:port

# Proxy Settings
PROXY_TIMEOUT=15
PROXY_ROTATION_PER_ROW=true
PROXY_RETRY_COUNT=2
PROXY_FALLBACK_TO_DIRECT=true
