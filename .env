# ── File Paths ──────────────────────────────────────────
INPUT_FILE=Split_Data_Part_1.csv
OUTPUT_FILE=Enriched_Data_Output_Ultimate.csv

# ── Timing ───────────────────────────────────────────────
DELAY_SECONDS=15
BLOCK_WAIT_MINUTES=30

# ── Behaviour ────────────────────────────────────────────
HEADLESS=true
MIN_CONFIDENCE_SCORE=60

# ── Proxy Configuration ──────────────────────────────────
# Options: "none", "brightdata", "oxylabs", "smartproxy", "manual"
PROXY_SERVICE=none

# Bright Data (formerly Luminati) - https://brightdata.com
# PROXY_SERVICE=brightdata
# BRIGHTDATA_USERNAME=your-username
# BRIGHTDATA_PASSWORD=your-password
# BRIGHTDATA_ZONE=residential

# Oxylabs - https://oxylabs.io
# PROXY_SERVICE=oxylabs
# OXYLABS_USERNAME=your-username
# OXYLABS_PASSWORD=your-password

# SmartProxy - https://smartproxy.com
# PROXY_SERVICE=smartproxy
# SMARTPROXY_USERNAME=your-username
# SMARTPROXY_PASSWORD=your-password

# Proxy Settings
PROXY_TIMEOUT=15
PROXY_ROTATION_PER_ROW=true
PROXY_RETRY_COUNT=2
PROXY_FALLBACK_TO_DIRECT=true
